# ===========================================
# Xynapse IDE — .gitignore
# ===========================================

# ===========================================
# Node.js
# ===========================================
node_modules/
.npm
.yarn/
.pnp.*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===========================================
# Build outputs (regenerated by npm run build)
# ===========================================
out/
dist/
build/
*.vsix
*.js.map
*.tsbuildinfo

# ===========================================
# Plugins source (not part of distribution)
# ===========================================
plugins/
/continue-main/

# ===========================================
# Personal scripts and notes (not part of IDE)
# ===========================================
/cu-*
/done*.txt
/clean-compile.bat
/compile-vscode.bat
/control-ultra.cmd
/original_xynapse.bat
/patch-gui-error.js
/MODEL-SYSTEM.md
/0

# ===========================================
# AI assistants / code agents — config files
# ===========================================
.agent/
.claude/
.claude
.claude*
CLAUDE.md
claude.md
Claude.md
.claudeignore
.clauderc
.clauderc.*
claude.json
claude.yaml
claude.yml
.anthropic/
.anthropic
anthropic.json
anthropic.yaml
anthropic.yml
.cursor/
.cursor
.copilot/
.github/copilot/
.ai/
.aider*
.xynapse/
.tabby/
.codeium/

# ===========================================
# Security — API keys, credentials, secrets
# ===========================================
.env
.env.*
*.env
secrets.json
secrets.yaml
secrets.yml
credentials.json
credentials.yaml
credentials.yml
*.pem
*.key
*.secret
*.p12
*.pfx
*.crt
*.cer
api_keys.*
api-keys.*
apikeys.*
token.json
tokens.json
auth.json
oauth.json
*.keystore
*.jks
private_key*
service_account*.json
google-credentials.json
firebase-credentials.json
aws-credentials
.aws/
.ssh/
id_rsa*
id_ed25519*
*.pub

# ===========================================
# Config files with potential secrets
# ===========================================
configi/
*.local.json
*.local.yaml
*.local.yml

# ===========================================
# Logs
# ===========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ===========================================
# OS files
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
\#*\#
.#*

# ===========================================
# Test and coverage
# ===========================================
coverage/
.nyc_output/
*.lcov

# ===========================================
# Temporary files
# ===========================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
nul

# ===========================================
# Themes (optional, not used)
# ===========================================
themes/

# ===========================================
# Git LFS pointer stubs (tabby, not needed)
# ===========================================
plugins/tabby-main/clients/tabby-agent/wasm/*.wasm
plugins/tabby-main/clients/vscode/assets/*.png
plugins/tabby-main/clients/vscode/assets/*.svg
plugins/tabby-main/clients/vscode/assets/walkthroughs/*.png
plugins/tabby-main/clients/intellij/src/main/resources/META-INF/pluginIcon.svg
plugins/tabby-main/website/**/*.png
plugins/tabby-main/website/**/*.gif

# ===========================================
# Xynapse IDE — .gitignore
# ===========================================

# ===========================================
# Node.js
# ===========================================
node_modules/
.npm
.yarn/
.pnp.*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===========================================
# Build outputs (regenerated by npm run build)
# ===========================================
out/
dist/
build/
*.vsix
*.js.map
*.tsbuildinfo

# ===========================================
# Source directories (not part of distribution)
# ===========================================
plugins/
/continue-main/
/extensions/
/диплом/

# ===========================================
# Personal scripts and notes (not part of IDE)
# ===========================================
/cu-*
/done*.txt
/clean-compile.bat
/compile-vscode.bat
/control-ultra.cmd
/original_xynapse.bat
/patch-gui-error.js
/MODEL-SYSTEM.md
/0

# ===========================================
# AI code agents — BLOCK ALL config/metadata
# ===========================================
# Claude / Anthropic
.claude/
.claude
.claude*
**/CLAUDE.md
**/claude.md
**/Claude.md
**/.claudeignore
**/.clauderc
**/.clauderc.*
**/claude.json
**/claude.yaml
**/claude.yml
**/.anthropic/
**/.anthropic
**/anthropic.json
**/anthropic.yaml
**/anthropic.yml

# Cursor
.cursor/
.cursor

# Copilot
.copilot/
.github/copilot/

# Other AI agents
.agent/
.ai/
.aider*
.tabby/
.codeium/
.continue/
.continuerc*
.augment/
.windsurf/
.devin/
.sourcegraph/
.cody/
.tabnine/

# Runtime config (user-specific, may contain keys)
.xynapse/

# ===========================================
# Security — API keys, credentials, secrets
# ===========================================
.env
.env.*
*.env
secrets.json
secrets.yaml
secrets.yml
credentials.json
credentials.yaml
credentials.yml
*.pem
*.key
*.secret
*.p12
*.pfx
*.crt
*.cer
api_keys.*
api-keys.*
apikeys.*
token.json
tokens.json
auth.json
oauth.json
*.keystore
*.jks
private_key*
service_account*.json
google-credentials.json
firebase-credentials.json
aws-credentials
.aws/
.ssh/
id_rsa*
id_ed25519*
*.pub

# ===========================================
# Config files with potential secrets
# ===========================================
configi/
*.local.json
*.local.yaml
*.local.yml

# ===========================================
# Logs
# ===========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ===========================================
# OS files
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
\#*\#
.#*

# ===========================================
# Test and coverage
# ===========================================
coverage/
.nyc_output/
*.lcov

# ===========================================
# Temporary files
# ===========================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
nul
